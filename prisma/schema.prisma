// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  VENDOR
  CONSUMER
  // role is optional during setup; null means not yet chosen
}

enum CompanyStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProductStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum ModelType {
  MARKETPLACE
  WHOLESALE
}

// new enums

enum CommerceModel {
  MARKETPLACE
  WHOLESALE
  HYBRID
}

enum ListingOwner {
  VENDOR
  TERRA
}

enum FulfillmentType {
  PICKUP
  LOCAL_DELIVERY
  SHIP
}

enum ProductCategory {
  WINE
  OLIVE_OIL
  SPIRITS
  BEER
  FOOD
  ACCESSORIES
  MERCH
}

// Controls staged public visibility — content can be fully prepared
// before being made public. LIVE is the only state visible to the public.
enum ContentStatus {
  DRAFT      // being entered by vendor/admin
  IN_REVIEW  // sample received, Terra Trionfo reviewing
  READY      // approved internally, not yet public
  LIVE       // publicly visible on the storefront
}

enum AgeVerificationStatus {
  UNVERIFIED   // DOB not yet provided
  ELIGIBLE     // 21+ confirmed from DOB
  INELIGIBLE   // under 21
}

// Release intelligence — catalogued exposure tier for admin prioritisation
enum ExposureTier {
  LOW       // No active demand signals; de-prioritise in catalog
  STANDARD  // Typical listing with some signals
  PRIORITY  // Strong signals; surface prominently
  LIMITED   // Limited allocation in high demand
}

// Release intelligence — computed monitor state for a product
enum ReleaseMonitorStatus {
  STABLE              // Healthy, no action required
  NEEDS_REVIEW        // Mixed signals, human review recommended
  HIGH_DEMAND         // Strong time-decayed signal score
  UNDERPERFORMING     // Live with no demand signals
  ALLOCATION_PRESSURE // Waitlist > available inventory
  UPCOMING_INTEREST   // Pre-release wine with early sign-ups
}

// Recommendation workflow — tracks whether a recommendation has been acted on
enum RecommendationStatus {
  OPEN       // Generated, not yet reviewed by anyone
  REVIEWED   // Admin has seen and acknowledged it
  ACTIONED   // A concrete action was taken
  DISMISSED  // Recommendation noted but not acted on
}

// Recommendation workflow — type of action taken against a recommendation
enum RecommendationActionType {
  NONE
  ACCELERATE_RELEASE
  HOLD_RELEASE
  INCREASE_ALLOCATION
  REDUCE_EXPOSURE
  INCREASE_MERCHANDISING
  MAINTAIN
  DISMISSED
}

// Recommendation resolution — outcome tracking after an action was taken
// Separate from workflow status: ACTIONED means someone did something;
// RESOLVED means the underlying problem actually improved.
enum RecommendationResolutionStatus {
  UNRESOLVED        // Action taken, outcome not yet clear (< 14 days)
  IMPROVING         // Early positive signals detected
  RESOLVED          // Problem confirmed resolved by signal data
  REQUIRES_FOLLOW_UP // Action taken but signals have not improved
}

// Recommendation effectiveness — compares pre-action vs post-action signal state
// Answers: did the action actually move the needle?
enum EffectivenessDelta {
  POSITIVE_SHIFT        // Signal score improved meaningfully after action
  NO_MEANINGFUL_CHANGE  // Score within noise threshold — action inconclusive
  NEGATIVE_SHIFT        // Score declined after action — worth reviewing
  MIXED_RESULT          // Some signals improved, others did not
}

// Bias governance — whether the learned bias weights have enough data to trust
enum BiasDataSufficiencyStatus {
  INSUFFICIENT  // < 3 measured outcomes — do not apply
  MARGINAL      // 3–9 outcomes — observe only
  SUFFICIENT    // 10–24 outcomes — can apply cautiously
  STRONG        // 25+ outcomes — full confidence
}

// Bias governance — what the bias engine is currently allowed to do
enum BiasMode {
  OFF                  // Weights computed but never applied
  OBSERVE_ONLY         // Weights monitored but not applied to recommendations
  APPLY_TO_CONFIDENCE  // Weights applied to confidence scores at generation time
}

// Phase 13 — Planning workflow: what decision the admin made against an allocation plan
enum PlanningDecisionStatus {
  PENDING    // Plan generated; no human decision yet
  ACCEPTED   // Admin accepted the engine recommendation verbatim
  OVERRIDDEN // Admin chose different allocation/timing/rollout values
  DEFERRED   // Decision postponed — revisit when signal changes
}

// Phase 14 — Execution tracking: what was actually done vs what was decided
enum PlanExecutionStatus {
  PENDING      // Decision made, execution not yet recorded
  EXECUTED     // Fully executed as planned (matches selected values)
  PARTIAL      // Some elements executed, others not
  DEVIATED     // Executed but different from the selected plan
  NOT_EXECUTED // Decision was made, plan was never carried out
}

model User {
  id             String    @id @default(cuid())
  name           String
  email          String    @unique
  passwordHash   String
  role           UserRole? // nullable until setup completed
  profileCompleted Boolean @default(false)

  // Customer profile fields
  firstName             String?
  lastName              String?
  phone                 String?
  dateOfBirth           DateTime?
  ageVerificationStatus AgeVerificationStatus @default(UNVERIFIED)
  ageVerifiedAt         DateTime?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  companies Company[]
  orders    Order[]
  addresses CustomerAddress[]
  recommendationActions ProductRecommendationHistory[]
  planningDecisions     ProductPlanningDecision[]

  @@map("users")
}

model Company {
  id           String        @id @default(cuid())
  name         String
  slug         String?       @unique
  contactEmail String
  phone        String?
  address      String?
  description  String?
  shortDescription String?
  bio          String?
  story        String?
  region       String?
  subregion    String?
  country      String?
  website      String?
  heroImageUrl String?
  galleryImages      String[]   @default([])
  locationLat        Float?
  locationLng        Float?
  sustainablePractices String?
  winemakerName      String?
  winemakerBio       String?
  foodPairingNotes   String?
  foundedYear        Int?
  isFoundingProducer Boolean    @default(false)
  contentStatus ContentStatus @default(DRAFT)
  status       CompanyStatus @default(PENDING)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  // Relations
  ownerId  String
  owner    User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  products Product[]

  @@map("companies")
}

model Product {
  id          String        @id @default(cuid())
  name        String
  slug        String?       @unique
  description String?
  category    ProductCategory
  imageUrl    String?

  // Producer attribution (may differ from company name for display)
  producerDisplayName String?

  // Wine / origin metadata (all optional — graceful on non-wine SKUs)
  vintage            Int?
  appellation        String?
  designation        String?
  country            String?
  region             String?
  subregion          String?
  grapeVarietals     String[]  @default([])
  wineStyle          String?
  body               String?
  acidity            String?
  tannin             String?
  abv                Float?
  bottleSizeMl       Int?

  // Tasting profile
  tastingNotesShort  String?
  tastingNotesFull   String?
  aromaNotes         String?
  palateNotes        String?
  finishNotes        String?

  // Production
  vinification       String?
  aging              String?
  vineyardNotes      String?

  // Serving
  servingTemperature String?
  decantingNotes     String?
  foodPairings       String[]  @default([])
  sustainabilityNotes String?

  // Editorial
  producerStoryExcerpt String?
  isLimitedAllocation Boolean   @default(false)
  isFeatured          Boolean   @default(false)
  isFoundingWine      Boolean   @default(false)
  badgeText           String?
  contentStatus       ContentStatus @default(DRAFT)

  // Commerce model fields
  commerceModel   CommerceModel @default(MARKETPLACE)
  listingOwner    ListingOwner  @default(VENDOR)
  vendorPriceCents Int?
  wholesalePriceCents Int?
  retailPriceCents  Int            // required for consumer checkout

  allowedFulfillment FulfillmentType[] @default([PICKUP, LOCAL_DELIVERY])

  inventory Int     @default(0)
  status    ProductStatus @default(PENDING)

  // Release intelligence metadata — populated by admin review or optimization engine
  releaseActivatedAt       DateTime?
  releaseLastReviewedAt    DateTime?
  allocationLastAdjustedAt DateTime?
  releasePriority          Int?
  releaseMonitorStatus     ReleaseMonitorStatus?
  exposureTier             ExposureTier?
  lastRecommendationAt     DateTime?

  // Recommendation workflow — tracks review/action lifecycle per recommendation cycle
  recommendationStatus     RecommendationStatus?
  recommendationActionType RecommendationActionType?
  recommendationNotes      String?
  lastRecommendationReviewedAt  DateTime?
  lastRecommendationActionedAt  DateTime?

  // Recommendation resolution — outcome tracking after ACTIONED (separate from workflow)
  recommendationResolutionStatus RecommendationResolutionStatus?
  lastRecommendationResolvedAt   DateTime?

  // Recommendation effectiveness — pre/post signal comparison (written by follow-up check)
  preActionMonitorStatus      ReleaseMonitorStatus? // signal state at moment of ACTIONED
  preActionExposureTier       ExposureTier?         // tier at moment of ACTIONED
  preActionSignalScore        Int?                  // 0–100 score at moment of ACTIONED
  postActionSignalScore       Int?                  // 0–100 score at latest follow-up check
  effectivenessDelta          EffectivenessDelta?   // derived comparison
  effectivenessReason         String?               // human-readable explanation
  effectivenessLastComputedAt DateTime?             // when delta was last derived

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  companyId       String
  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  orderItems      OrderItem[]
  restaurantWines RestaurantWine[]
  waitlists       Waitlist[]
  tradeInterests  TradeInterest[]
  recommendationHistory ProductRecommendationHistory[]
  planningDecisions     ProductPlanningDecision[]

  @@map("products")
}

// Audit trail for recommendation workflow transitions
model ProductRecommendationHistory {
  id        String @id @default(cuid())

  // Snapshot of what changed
  previousStatus     RecommendationStatus?
  newStatus          RecommendationStatus
  previousActionType RecommendationActionType?
  newActionType      RecommendationActionType?
  note               String?

  // Context snapshot — what the engine said at the moment of the action
  releaseMonitorStatus ReleaseMonitorStatus?
  exposureTier         ExposureTier?

  // Resolution state snapshot — before/after when a resolution update was made
  previousResolutionStatus RecommendationResolutionStatus?
  newResolutionStatus      RecommendationResolutionStatus?

  // Effectiveness snapshot — populated on follow-up check rows
  preActionSignalScore  Int?
  postActionSignalScore Int?
  effectivenessDelta    EffectivenessDelta?

  // Confidence snapshot — captured at ACTIONED time for calibration tracking
  // Enables: "when we said high confidence, were we right more often?"
  baseConfidenceScore     Int?     // 0–100 numeric confidence before any bias adjustment
  adjustedConfidenceScore Int?     // 0–100 numeric confidence after bias adjustment (may equal base)
  biasApplied             Boolean? // whether a bias multiplier was applied at generation time
  biasMultiplier          Float?   // effective multiplier used (1.0 = no adjustment)

  // Who did it
  changedByUserId String
  changedBy       User   @relation(fields: [changedByUserId], references: [id])

  // When
  createdAt DateTime @default(now())

  // Foreign key
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([createdAt])
  @@map("product_recommendation_history")
}

// Phase 13 — one row per planning decision event per product.
// Captures what the engine recommended vs what the admin actually chose.
// Multiple rows per product allowed — latest row = current decision state.
model ProductPlanningDecision {
  id String @id @default(cuid())

  // What the engine recommended (snapshot at decision time)
  recommendedAllocationSizing String
  recommendedReleaseTiming    String
  recommendedRolloutMode      String
  recommendedPlanConfidence   String  // 'high' | 'medium' | 'low'

  // Signal snapshot at decision time — enables outcome comparison later
  signalScoreAtDecision Float?
  inventoryAtDecision   Int?

  // Human decision
  decisionStatus           PlanningDecisionStatus @default(PENDING)
  selectedAllocationSizing String?  // null when DEFERRED or PENDING
  selectedReleaseTiming    String?
  selectedRolloutMode      String?
  planningDecisionNotes    String?

  // Phase 14 — Execution tracking
  executionStatus          PlanExecutionStatus @default(PENDING)
  executedAllocationSizing String?
  executedReleaseTiming    String?
  executedRolloutMode      String?
  executionNotes           String?
  executedAt               DateTime?
  executedByUserId         String?   // stored without named relation to avoid dual User FK complexity
  executedByUserName       String?   // denormalised for display
  planAdherence            String?   // derived label: matched_recommendation | matched_decision | recommendation_restored | deviated_from_decision | partially_executed | not_executed

  // Audit
  plannedByUserId String
  plannedBy       User    @relation(fields: [plannedByUserId], references: [id])
  plannedAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // FK
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([decisionStatus])
  @@index([plannedAt])
  @@map("product_planning_decisions")
}

// Singleton row controlling whether learned bias weights are applied
// to future recommendation confidence scores.
// Only one row ever exists (id = 'singleton').
model BiasGovernance {
  id                          String                     @id @default("singleton")
  biasEnabled                 Boolean                    @default(false)
  biasMode                    BiasMode                   @default(OBSERVE_ONLY)
  biasDataSufficiencyStatus   BiasDataSufficiencyStatus?
  biasLastAppliedAt           DateTime?
  biasLastComputedAt          DateTime?
  totalMeasuredAtLastCompute  Int?
  updatedAt                   DateTime                   @updatedAt
  updatedByUserId             String?

  @@map("bias_governance")
}

model Order {
  id        String      @id @default(cuid())
  total     Float
  status    OrderStatus @default(PENDING)
  fulfillmentType FulfillmentType
  deliveryFeeCents Int @default(0)
  scheduledDeliveryDate DateTime?
  pickupLocationId String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  // Relations
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        String    @id @default(cuid())
  quantity  Int
  unitPrice Float
  commerceModel CommerceModel // Track which model was used at time of sale

  // Relations
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Settings {
  id                           String   @id @default(cuid())
  defaultMarketplaceMarkupPercent Float @default(20)

  // Fulfillment configuration
  deliveryAllowedStates String[] @default(["MA"])
  deliveryDaysOfWeek    Int[]    @default([2,4,6]) // ISO Mon=1..Sun=7
  deliveryFeeCents      Int      @default(0)

  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  @@map("settings")
}

model PickupLocation {
  id          String  @id @default(cuid())
  name        String
  address     String
  city        String
  state       String
  zipCode     String?
  isActive    Boolean @default(true)

  latitude    Float?
  longitude   Float?
  pickupType  String  @default("WAREHOUSE") // WAREHOUSE | FUTURE_PARTNER

  status        CompanyStatus @default(PENDING)
  contentStatus ContentStatus @default(DRAFT)

  schedules PickupSchedule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("pickup_locations")
}

model DeliveryZone {
  id          String  @id @default(cuid())
  name        String
  code        String  @unique
  description String?

  isActive Boolean @default(true)

  routes DeliveryRoute[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("delivery_zones")
}

model DeliveryRoute {
  id String @id @default(cuid())

  zoneId String
  zone   DeliveryZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  deliveryDay Int // 0-6 (Sunday=0, Monday=1, ..., Saturday=6)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("delivery_routes")
}

model PickupSchedule {
  id String @id @default(cuid())

  locationId String
  location   PickupLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  pickupDay Int // 0-6 (Sunday=0, Monday=1, ..., Saturday=6)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  @@map("pickup_schedules")
}

model CustomerAddress {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  label    String @default("Home")  // "Home" | "Work" | "Other"
  address1 String
  address2 String?
  city     String
  state    String
  zipCode  String
  isDefault Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("customer_addresses")
}

model Restaurant {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?
  website     String?

  address String
  city    String
  state   String
  zipCode String

  latitude  Float?
  longitude Float?

  heroImageUrl  String?
  galleryImages String[] @default([])

  cuisineType String?
  priceRange  String?

  isFeatured Boolean @default(false)

  status        CompanyStatus @default(PENDING)
  contentStatus ContentStatus @default(DRAFT)

  wines RestaurantWine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("restaurants")
}

model RestaurantWine {
  id String @id @default(cuid())

  restaurantId String
  productId    String

  servingType String  @default("BOTTLE_LIST") // BY_GLASS | BOTTLE_LIST
  notes       String?

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, productId])
  @@map("restaurant_wines")
}

// Consumer demand signal — who wants to be notified when a wine is available
model Waitlist {
  id        String   @id @default(cuid())
  email     String
  notes     String?
  createdAt DateTime @default(now())

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([email])
  @@map("waitlists")
}

// B2B trade interest — importers, restaurants, distributors
model TradeInterest {
  id          String   @id @default(cuid())
  name        String
  business    String
  email       String
  accountType String   // restaurant | retailer | distributor | other
  region      String?
  caseInterest Int?
  notes       String?
  createdAt   DateTime @default(now())

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([email])
  @@map("trade_interests")
}
