// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  VENDOR
  CONSUMER
  // role is optional during setup; null means not yet chosen
}

enum CompanyStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProductStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum ModelType {
  MARKETPLACE
  WHOLESALE
}

// new enums

enum CommerceModel {
  MARKETPLACE
  WHOLESALE
  HYBRID
}

enum ListingOwner {
  VENDOR
  TERRA
}

enum FulfillmentType {
  PICKUP
  LOCAL_DELIVERY
  SHIP
}

enum ProductCategory {
  WINE
  OLIVE_OIL
  SPIRITS
  BEER
  FOOD
  ACCESSORIES
  MERCH
}

// Controls staged public visibility — content can be fully prepared
// before being made public. LIVE is the only state visible to the public.
enum ContentStatus {
  DRAFT      // being entered by vendor/admin
  IN_REVIEW  // sample received, Terra Trionfo reviewing
  READY      // approved internally, not yet public
  LIVE       // publicly visible on the storefront
}

model User {
  id             String    @id @default(cuid())
  name           String
  email          String    @unique
  passwordHash   String
  role           UserRole? // nullable until setup completed
  profileCompleted Boolean @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  companies Company[]
  orders    Order[]

  @@map("users")
}

model Company {
  id           String        @id @default(cuid())
  name         String
  slug         String?       @unique
  contactEmail String
  phone        String?
  address      String?
  description  String?
  shortDescription String?
  bio          String?
  story        String?
  region       String?
  subregion    String?
  country      String?
  website      String?
  heroImageUrl String?
  galleryImages      String[]   @default([])
  locationLat        Float?
  locationLng        Float?
  sustainablePractices String?
  winemakerName      String?
  winemakerBio       String?
  foodPairingNotes   String?
  foundedYear        Int?
  isFoundingProducer Boolean    @default(false)
  contentStatus ContentStatus @default(DRAFT)
  status       CompanyStatus @default(PENDING)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  // Relations
  ownerId  String
  owner    User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  products Product[]

  @@map("companies")
}

model Product {
  id          String        @id @default(cuid())
  name        String
  slug        String?       @unique
  description String?
  category    ProductCategory
  imageUrl    String?

  // Producer attribution (may differ from company name for display)
  producerDisplayName String?

  // Wine / origin metadata (all optional — graceful on non-wine SKUs)
  vintage            Int?
  appellation        String?
  designation        String?
  country            String?
  region             String?
  subregion          String?
  grapeVarietals     String[]  @default([])
  wineStyle          String?
  body               String?
  acidity            String?
  tannin             String?
  abv                Float?
  bottleSizeMl       Int?

  // Tasting profile
  tastingNotesShort  String?
  tastingNotesFull   String?
  aromaNotes         String?
  palateNotes        String?
  finishNotes        String?

  // Production
  vinification       String?
  aging              String?
  vineyardNotes      String?

  // Serving
  servingTemperature String?
  decantingNotes     String?
  foodPairings       String[]  @default([])
  sustainabilityNotes String?

  // Editorial
  producerStoryExcerpt String?
  isLimitedAllocation Boolean   @default(false)
  isFeatured          Boolean   @default(false)
  isFoundingWine      Boolean   @default(false)
  badgeText           String?
  contentStatus       ContentStatus @default(DRAFT)

  // Commerce model fields
  commerceModel   CommerceModel @default(MARKETPLACE)
  listingOwner    ListingOwner  @default(VENDOR)
  vendorPriceCents Int?
  wholesalePriceCents Int?
  retailPriceCents  Int            // required for consumer checkout

  allowedFulfillment FulfillmentType[] @default([PICKUP, LOCAL_DELIVERY])

  inventory Int     @default(0)
  status    ProductStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  companyId  String
  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@map("products")
}

model Order {
  id        String      @id @default(cuid())
  total     Float
  status    OrderStatus @default(PENDING)
  fulfillmentType FulfillmentType
  deliveryFeeCents Int @default(0)
  scheduledDeliveryDate DateTime?
  pickupLocationId String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  // Relations
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        String    @id @default(cuid())
  quantity  Int
  unitPrice Float
  commerceModel CommerceModel // Track which model was used at time of sale

  // Relations
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Settings {
  id                           String   @id @default(cuid())
  defaultMarketplaceMarkupPercent Float @default(20)

  // Fulfillment configuration
  deliveryAllowedStates String[] @default(["MA"])
  deliveryDaysOfWeek    Int[]    @default([2,4,6]) // ISO Mon=1..Sun=7
  deliveryFeeCents      Int      @default(0)

  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  @@map("settings")
}

model PickupLocation {
  id       String  @id @default(cuid())
  name     String
  address  String
  city     String
  state    String
  zipCode  String?
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("pickup_locations")
}
